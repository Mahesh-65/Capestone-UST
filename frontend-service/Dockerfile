FROM node:20-alpine AS deps
WORKDIR /app
COPY package.json package-lock.json* ./
RUN npm install

FROM node:20-alpine AS builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY . .
ARG NEXT_PUBLIC_USERS_API
ARG NEXT_PUBLIC_GAMES_API
ARG NEXT_PUBLIC_VENUES_API
ARG NEXT_PUBLIC_TOURNAMENTS_API
ARG NEXT_PUBLIC_BILLING_API
ARG NEXT_PUBLIC_NOTIFICATIONS_API
ENV NEXT_PUBLIC_USERS_API=$NEXT_PUBLIC_USERS_API
ENV NEXT_PUBLIC_GAMES_API=$NEXT_PUBLIC_GAMES_API
ENV NEXT_PUBLIC_VENUES_API=$NEXT_PUBLIC_VENUES_API
ENV NEXT_PUBLIC_TOURNAMENTS_API=$NEXT_PUBLIC_TOURNAMENTS_API
ENV NEXT_PUBLIC_BILLING_API=$NEXT_PUBLIC_BILLING_API
ENV NEXT_PUBLIC_NOTIFICATIONS_API=$NEXT_PUBLIC_NOTIFICATIONS_API
RUN npm run build

FROM node:20-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production
COPY --from=builder /app/.next ./.next
COPY --from=builder /app/public ./public
COPY --from=builder /app/package.json ./package.json
COPY --from=builder /app/node_modules ./node_modules
EXPOSE 3000
CMD ["npm", "run", "start"]
